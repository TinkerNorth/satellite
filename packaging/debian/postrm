#!/bin/sh
# postrm: runs after files are removed from the filesystem.
#
# dpkg removes /usr/lib/udev/rules.d/70-satellite-uinput.rules and
# /usr/lib/modules-load.d/satellite.conf for us; we just need to ask
# udev to drop the rule from its in-memory state. We do *not* remove
# users from the `input` group; other tools (joystick devices,
# barcode scanners, accessibility software) rely on it.
set -e

case "$1" in
    remove|purge|upgrade|failed-upgrade|abort-install|abort-upgrade|disappear)
        if command -v udevadm >/dev/null 2>&1; then
            udevadm control --reload-rules || true
        fi
    ;;

    *)
        echo "postrm called with unknown argument \`$1'" >&2
        exit 1
    ;;
esac

exit 0
