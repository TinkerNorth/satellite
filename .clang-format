# Satellite — clang-format configuration
# Based on LLVM style, tuned to match the existing codebase.
# Run:  clang-format -i src/*.cpp src/*.h controller-*.cpp

BasedOnStyle: LLVM

# Indentation
IndentWidth: 4
TabWidth: 4
UseTab: Never
IndentCaseLabels: false
NamespaceIndentation: None

# Braces
BreakBeforeBraces: Attach            # K&R: opening brace on same line
AllowShortBlocksOnASingleLine: Always
AllowShortFunctionsOnASingleLine: All
AllowShortIfStatementsOnASingleLine: WithoutElse
AllowShortLoopsOnASingleLine: true
AllowShortLambdasOnASingleLine: All

# Line length
ColumnLimit: 100

# Alignment
AlignAfterOpenBracket: Align
AlignConsecutiveAssignments: false
AlignConsecutiveDeclarations: false
AlignOperands: Align
AlignTrailingComments: true

# Spaces
SpaceBeforeParens: ControlStatements  # if (...) but func(...)
SpaceAfterCStyleCast: false
SpacesInParentheses: false
SpacesInSquareBrackets: false
SpaceBeforeSquareBrackets: false

# Includes
SortIncludes: false                   # don't reorder — Windows headers are order-sensitive
IncludeBlocks: Preserve

# Pointer/reference alignment
PointerAlignment: Left                # char* buf  (not  char *buf)
ReferenceAlignment: Left

# Other
AllowAllParametersOfDeclarationOnNextLine: true
BinPackArguments: true
BinPackParameters: true
BreakConstructorInitializers: BeforeColon
ConstructorInitializerIndentWidth: 4
ContinuationIndentWidth: 4
Cpp11BracedListStyle: true
DerivePointerAlignment: false
FixNamespaceComments: true
MaxEmptyLinesToKeep: 1
ReflowComments: true
SpaceBeforeCpp11BracedList: false
Standard: c++17

